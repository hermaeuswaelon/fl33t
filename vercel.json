{
  "name": "aethelgard-fleet",
  "version": 2,
  "builds": [
    { "src": "/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/SOP/(.*)", "dest": "/SOP/$1" },
    { "src": "/AGENTS/(.*)", "dest": "/AGENTS/$1" }
  ],
  "headers": [
    {
      "source": "/*",
      "headers": [
        { "key": "X-Fleet", "value": "Aethelgard" },
        { "key": "X-Glyph", "value": "\\u2394" }
      ]
    }
  ]
}
